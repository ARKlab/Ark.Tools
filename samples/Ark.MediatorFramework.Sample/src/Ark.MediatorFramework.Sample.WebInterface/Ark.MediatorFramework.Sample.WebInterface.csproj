<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="MessagePack.NodaTime" />
    <PackageReference Include="Grpc.StatusProto" />
    <PackageReference Include="Hellang.Middleware.ProblemDetails" />
    <PackageReference Include="protobuf-net.Grpc.AspNetCore" />
    <PackageReference Include="System.ServiceModel.Primitives" />
    <PackageReference Include="Ark.Tools.MediatorFramework.MinimalApi" />
    <PackageReference Include="Ark.Tools.MediatorFramework.Rebus" />
    <PackageReference Include="Ark.Tools.MediatorFramework.Grpc" />
    <ProjectReference Include="..\Ark.MediatorFramework.Sample.Application\Ark.MediatorFramework.Sample.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\common\Ark.Tools.Rebus\Ark.Tools.Rebus.csproj" />
    <ProjectReference Include="..\..\..\..\src\aspnetcore\Ark.Tools.AspNetCore.MessagePack\Ark.Tools.AspNetCore.MessagePack.csproj" />
    <ProjectReference Include="..\Ark.MediatorFramework.ProtoGenerator\Ark.MediatorFramework.ProtoGenerator.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <PropertyGroup>
    <ProtoOutputFile>$(MSBuildProjectDirectory)/$(AssemblyName).proto</ProtoOutputFile>
    <ProtoGeneratorAssembly>$(MSBuildProjectDirectory)/../Ark.MediatorFramework.ProtoGenerator/bin/$(Configuration)/net10.0/Ark.MediatorFramework.ProtoGenerator.dll</ProtoGeneratorAssembly>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(ProtoOutputFile)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="EmitMediatorProto" AfterTargets="CoreCompile" BeforeTargets="CopyFilesToOutputDirectory">
    <Exec Command="dotnet &quot;$(ProtoGeneratorAssembly)&quot; &quot;$(MSBuildProjectDirectory)/../Ark.MediatorFramework.Sample.Application/bin/$(Configuration)/net10.0/Ark.MediatorFramework.Sample.Application.dll&quot; &quot;$(ProtoOutputFile)&quot;" />
  </Target>

</Project>
