<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="MessagePack.NodaTime" />
    <PackageReference Include="protobuf-net.Grpc.AspNetCore" />
    <PackageReference Include="System.ServiceModel.Primitives" />
    <ProjectReference Include="..\Ark.MediatorFramework.Sample.Application\Ark.MediatorFramework.Sample.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\common\Ark.Tools.Rebus\Ark.Tools.Rebus.csproj" />
    <ProjectReference Include="..\..\..\..\src\aspnetcore\Ark.Tools.AspNetCore.MessagePack\Ark.Tools.AspNetCore.MessagePack.csproj" />
    <ProjectReference Include="..\Ark.MediatorFramework.Generators\Ark.MediatorFramework.Generators.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\Ark.MediatorFramework.ProtoGenerator\Ark.MediatorFramework.ProtoGenerator.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <PropertyGroup>
    <ProtoOutputFile>$(ProjectDir)$(AssemblyName).proto</ProtoOutputFile>
    <ProtoGeneratorAssembly>$(ProjectDir)..\Ark.MediatorFramework.ProtoGenerator\bin\$(Configuration)\net10.0\Ark.MediatorFramework.ProtoGenerator.dll</ProtoGeneratorAssembly>
  </PropertyGroup>

  <Target Name="EmitMediatorProto" AfterTargets="CoreCompile" BeforeTargets="CopyFilesToOutputDirectory">
    <Exec Command="dotnet &quot;$(ProtoGeneratorAssembly)&quot; &quot;$(ProjectDir)..\Ark.MediatorFramework.Sample.Application\bin\$(Configuration)\net10.0\Ark.MediatorFramework.Sample.Application.dll&quot; &quot;$(ProtoOutputFile)&quot;" />
    <ItemGroup>
      <None Include="$(ProtoOutputFile)" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
  </Target>

</Project>
