<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Description>Transport-neutral exception to RFC 7807 ProblemDetails mapping for Ark.Tools applications</Description>
    <PackageTags>Ark;C#;.NET;Framework;AspNetCore;ProblemDetails</PackageTags>
    <Version>$(AspNetCoreGroupVersion)</Version>
    <VersionSuffix>$(AspNetCoreGroupVersionSuffix)</VersionSuffix>
    <Version Condition="'$(VersionSuffix)' != ''">$(Version)-$(VersionSuffix)</Version>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="FluentValidation" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\common\Ark.Tools.Authorization\Ark.Tools.Authorization.csproj" />
    <ProjectReference Include="..\..\common\Ark.Tools.Core\Ark.Tools.Core.csproj" />
    <ProjectReference Include="..\..\common\Ark.Tools.Sql.SqlServer\Ark.Tools.Sql.SqlServer.csproj" />
  </ItemGroup>

</Project>
