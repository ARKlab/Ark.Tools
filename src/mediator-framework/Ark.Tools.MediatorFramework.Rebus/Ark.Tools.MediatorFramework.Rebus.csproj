<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Rebus message-bus transport runtime package for Ark.Tools MediatorFramework. Bundles the source generator that emits RegisterArkRebusHandlers and IHandleMessages wrappers for [RebusMessage]-annotated contracts.</Description>
    <PackageTags>Ark;C#;.NET;Framework;Mediator;Rebus;Source Generator</PackageTags>
    <Version>$(ArkToolsCoreVersion)</Version>
    <VersionSuffix>$(ArkToolsCoreVersionSuffix)</VersionSuffix>
    <Version Condition="'$(VersionSuffix)' != ''">$(Version)-$(VersionSuffix)</Version>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Rebus.Protobuf" />
    <!-- Core transport-agnostic attributes and attachment abstractions. -->
    <ProjectReference Include="..\Ark.Tools.MediatorFramework\Ark.Tools.MediatorFramework.csproj" />
    <!-- Runtime dependencies used by the generated Rebus handlers. -->
    <ProjectReference Include="..\..\common\Ark.Tools.Rebus\Ark.Tools.Rebus.csproj" />
    <!-- The generator is applied as an analyzer when this package is project-referenced in
         development. When consumed via NuGet the generator DLL lives in analyzers/dotnet/cs/
         inside this package (see IncludeGeneratorInPackage target below). -->
    <ProjectReference Include="..\Ark.Tools.MediatorFramework.Rebus.Generators\Ark.Tools.MediatorFramework.Rebus.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <None Include="buildTransitive/Ark.Tools.MediatorFramework.Rebus.props" Pack="true"
          PackagePath="buildTransitive" />
  </ItemGroup>

  <!-- Pack the generator DLL into this NuGet package so that a PackageReference to
       Ark.Tools.MediatorFramework.Rebus automatically applies the analyzer. -->
  <Target Name="IncludeGeneratorInPackage" BeforeTargets="_GetPackageFiles">
    <ItemGroup>
      <None Include="$(MSBuildThisFileDirectory)..\Ark.Tools.MediatorFramework.Rebus.Generators\bin\$(Configuration)\netstandard2.0\Ark.Tools.MediatorFramework.Rebus.Generators.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false"
            Condition="Exists('$(MSBuildThisFileDirectory)..\Ark.Tools.MediatorFramework.Rebus.Generators\bin\$(Configuration)\netstandard2.0\Ark.Tools.MediatorFramework.Rebus.Generators.dll')" />
    </ItemGroup>
  </Target>

</Project>
