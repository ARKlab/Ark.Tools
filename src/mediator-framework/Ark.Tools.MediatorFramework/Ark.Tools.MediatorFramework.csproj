<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Transport markers and attachment abstractions for source-generated mediator endpoints</Description>
    <PackageTags>Ark;C#;.NET;Framework;Mediator;Minimal API;Rebus;gRPC</PackageTags>
    <Version>$(ArkToolsCoreVersion)</Version>
    <VersionSuffix>$(ArkToolsCoreVersionSuffix)</VersionSuffix>
    <Version Condition="'$(VersionSuffix)' != ''">$(Version)-$(VersionSuffix)</Version>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="protobuf-net" />
  </ItemGroup>

</Project>
