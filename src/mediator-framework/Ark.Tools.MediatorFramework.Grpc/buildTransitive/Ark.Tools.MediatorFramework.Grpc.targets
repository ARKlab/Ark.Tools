<Project>
  <Target Name="ArkExportProto"
          AfterTargets="Build"
          Condition="'$(ArkExportProtoDir)' != ''">
    <Exec Command="dotnet &quot;$(TargetPath)&quot; --ark-export-proto &quot;$(ArkExportProtoDir)&quot;" />
  </Target>

  <Target Name="ArkCopyAdditionalProto"
          AfterTargets="ArkExportProto"
          Condition="'$(ArkExportProtoDir)' != ''">
    <Copy SourceFiles="@(ArkAdditionalProto)"
          DestinationFiles="@(ArkAdditionalProto->'$(ArkExportProtoDir)/%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
